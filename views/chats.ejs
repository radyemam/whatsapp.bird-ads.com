<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المحادثات</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
    <style>
        /* Adjusted heights for desktop to prevent overflow */
        .chat-list {
            height: 100%;
            /* Full height minus top padding */
            overflow-y: auto;
            border-left: 1px solid rgba(255, 255, 255, 0.1);
        }

        .chat-view {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .messages-container {
            flex-grow: 1;
            overflow-y: auto;
            background: rgba(0, 0, 0, 0.2);
            /* WhatsApp-like background pattern could be added here */
        }

        .message-bubble {
            max-width: 75%;
            padding: 8px 12px;
            border-radius: 12px;
            margin-bottom: 8px;
            position: relative;
            line-height: 1.4;
        }

        .msg-user {
            background-color: #202c33;
            /* Dark mode incoming */
            color: #e9edef;
            align-self: flex-start;
            border-top-left-radius: 0;
        }

        .msg-model {
            background-color: #005c4b;
            /* WhatsApp Dark Green */
            color: #e9edef;
            align-self: flex-end;
            border-top-right-radius: 0;
        }

        .contact-item {
            cursor: pointer;
            transition: all 0.2s;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .contact-item:hover,
        .contact-item.active {
            background: rgba(255, 255, 255, 0.05);
        }

        .contact-avatar {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            font-size: 1.2rem;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Responsive Layout Classes */
        .chat-main-container {
            padding-top: 100px;
            padding-bottom: 50px;
            padding-left: 1.5rem;
            padding-right: 1.5rem;
            height: 100vh;
        }

        .chat-card-container {
            height: calc(100vh - 150px);
        }

        @media (max-width: 768px) {
            .chat-main-container {
                padding: 70px 0 0 0 !important;
                height: 100vh;
            }

            .chat-card-container {
                height: calc(100vh - 70px) !important;
                border-radius: 0 !important;
                border: none !important;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/navbar') %>

        <%- include('partials/sidebar') %>

            <!-- Adjusted container to match Instructions page -->
            <div class="container-fluid main-content px-4 px-lg-5">
                <div class="glass-card overflow-hidden p-0 animate-fade-in chat-card-container">
                    <div class="row h-100 g-0">

                        <!-- Chat List Pane -->
                        <div
                            class="col-md-3 chat-list p-0 bg-dark bg-opacity-10 <%= activeJid ? 'd-none d-md-block' : 'd-block' %>">
                            <div class="p-3 border-bottom border-secondary d-flex justify-content-between align-items-center"
                                style="background: rgba(30, 41, 59, 0.5);">
                                <h5 class="fw-bold m-0 text-white">الرسائل</h5>
                                <div class="badge bg-primary rounded-pill">
                                    <%= contacts.length %>
                                </div>
                            </div>

                            <div class="pt-0">
                                <% if(contacts.length===0) { %>
                                    <div class="text-center mt-5 text-white-50">
                                        <i class="bi bi-chat-square-dots fs-1 d-block mb-3 opacity-50"></i>
                                        <p>لا توجد محادثات بعد</p>
                                    </div>
                                    <% } %>

                                        <% contacts.forEach(contact=> { %>
                                            <a href="/dashboard/chats?jid=<%= contact.remoteJid %>"
                                                class="d-flex align-items-center p-3 text-decoration-none text-white contact-item <%= activeJid === contact.remoteJid ? 'active' : '' %>">
                                                <div class="contact-avatar me-3 flex-shrink-0">
                                                    <i class="bi bi-person-fill"></i>
                                                </div>
                                                <div class="overflow-hidden w-100">
                                                    <div class="d-flex justify-content-between">
                                                        <span class="fw-bold text-truncate">
                                                            <%= contact.remoteJid.split('@')[0] %>
                                                        </span>
                                                    </div>
                                                    <small class="text-white-50 d-block text-truncate"
                                                        style="font-size: 0.85rem;">
                                                        اضغط لعرض المحادثة
                                                    </small>
                                                </div>
                                            </a>
                                            <% }) %>
                            </div>
                        </div>

                        <!-- Chat View Pane -->
                        <div class="col-md-9 chat-view p-0 <%= activeJid ? 'd-flex' : 'd-none d-md-flex' %>"
                            style="background: #0b141a;">
                            <% if(activeJid) { %>
                                <!-- Header -->
                                <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom border-secondary sticky-top"
                                    style="background: #202c33;">
                                    <div class="d-flex align-items-center gap-3">
                                        <!-- Back Button (Mobile) -->
                                        <a href="/dashboard/chats" class="btn btn-link text-white d-md-none p-0 me-2">
                                            <i class="bi bi-arrow-right fs-4"></i>
                                        </a>

                                        <div class="contact-avatar" style="width: 40px; height: 40px; font-size: 1rem;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div>
                                            <h6 class="m-0 fw-bold text-white">
                                                <%= activeJid.split('@')[0] %>
                                            </h6>
                                            <small class="text-success" style="font-size: 0.75rem;">نشط الآن</small>
                                        </div>
                                    </div>

                                    <!-- Options Menu -->
                                    <div class="dropdown">
                                        <button class="btn btn-link text-white-50" type="button"
                                            data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical fs-5"></i>
                                        </button>
                                        <ul
                                            class="dropdown-menu dropdown-menu-end dropdown-menu-dark shadow border-secondary">
                                            <li>
                                                <form action="/dashboard/chats/delete" method="POST"
                                                    onsubmit="return confirm('هل أنت متأكد؟\nالذكاء الاصطناعي سيفقد كل الذاكرة مع هذا الشخص.')">
                                                    <input type="hidden" name="remoteJid" value="<%= activeJid %>">
                                                    <button type="submit"
                                                        class="dropdown-item text-danger d-flex align-items-center gap-2">
                                                        <i class="bi bi-trash3"></i>
                                                        <span class="d-none d-md-inline">حذف المحادثة</span>
                                                        <span class="d-md-none text-white">حذف المحادثة</span>
                                                        <!-- White text on mobile default if bg is dark, but user asked for NOT black on red. Let's force proper styling -->
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </div>

                                <!-- Messages -->
                                <div class="messages-container p-3 d-flex flex-column" id="chat-messages"
                                    style="background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png'); background-blend-mode: overlay; background-color: #0b141a;">
                                    <% messages.forEach(msg=> { %>
                                        <div
                                            class="message-bubble <%= msg.role === 'user' ? 'msg-user' : 'msg-model' %> shadow-sm animate-fade-in">
                                            <% if(msg.role !=='user' ) { %>
                                                <div class="d-flex align-items-center gap-1 mb-1 text-info"
                                                    style="font-size: 0.75rem;">
                                                    <i class="bi bi-robot"></i> AI Agent
                                                </div>
                                                <% } %>

                                                    <div class="message-text">
                                                        <%= msg.content %>
                                                    </div>

                                                    <div class="text-end mt-1 opacity-50" style="font-size: 0.65rem;">
                                                        <%= new Date(msg.createdAt).toLocaleTimeString('ar-EG',
                                                            {hour: '2-digit' , minute:'2-digit'}) %>
                                                            <% if(msg.role !=='user' ) { %> <i
                                                                    class="bi bi-check2-all ms-1"></i>
                                                                <% } %>
                                                    </div>
                                        </div>
                                        <% }) %>
                                </div>

                                <!-- Input Placeholder -->
                                <div class="p-3 border-top border-secondary" style="background: #202c33;">
                                    <div class="text-white-50 text-center py-2"
                                        style="background: rgba(255,255,255,0.05); border-radius: 8px;">
                                        <i class="bi bi-lock-fill me-1"></i> يتم الرد تلقائياً بواسطة البوت
                                    </div>
                                </div>

                                <% } else { %>
                                    <!-- Empty State -->
                                    <div
                                        class="d-flex flex-column align-items-center justify-content-center h-100 text-white-50">
                                        <i class="bi bi-whatsapp display-1 mb-4 opacity-25"></i>
                                        <h4 class="fw-normal">AI Agent WhatsApp Web</h4>
                                        <p class="small">اختر محادثة لعرض الرسائل</p>
                                    </div>
                                    <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Scroll to bottom script -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const container = document.getElementById('chat-messages');
                    if (container) {
                        container.scrollTop = container.scrollHeight;
                    }
                });
            </script>
</body>

</html>