<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الملف الشخصي</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">

</head>

<body>
    <%- include('partials/navbar') %>
        <%- include('partials/sidebar') %>

            <div class="container-fluid main-content px-4 px-lg-5">
                <div class="glass-card p-4 p-md-5 animate-fade-in">
                    <h3 class="mb-4 fw-bold border-bottom border-primary border-opacity-25 pb-3">إعدادات الأمان</h3>

                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert alert-success">تم تحديث كلمة المرور بنجاح!</div>
                        <% } %>

                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-danger">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form action="/dashboard/profile/password" method="POST">
                                        <div class="mb-4">
                                            <label class="form-label text-secondary">كلمة المرور الحالية</label>
                                            <input type="password" name="currentPassword" class="form-control" required>
                                        </div>
                                        <div class="mb-4">
                                            <label class="form-label text-secondary">كلمة المرور الجديدة</label>
                                            <input type="password" name="newPassword" class="form-control" minlength="6"
                                                required>
                                            <div class="form-text text-white-50">يجب أن تكون 6 أحرف على الأقل.
                                            </div>
                                        </div>
                                        <div class="mb-5">
                                            <label class="form-label text-secondary">تأكيد كلمة المرور
                                                الجديدة</label>
                                            <input type="password" name="confirmPassword" class="form-control" required>
                                        </div>
                                        <button type="submit" class="btn btn-primary px-5 py-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                fill="currentColor" class="bi bi-shield-lock-fill me-2"
                                                viewBox="0 0 16 16">
                                                <path fill-rule="evenodd"
                                                    d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.777 11.777 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7.159 7.159 0 0 0 1.048-.625 11.775 11.775 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.541 1.541 0 0 0-1.044-1.263 62.467 62.467 0 0 0-2.887-.87C9.843.266 8.69 0 8 0zm0 5a1.5 1.5 0 0 1 .5 2.915l.385 1.99a.5.5 0 0 1-.491.595h-.792a.5.5 0 0 1-.492-.595l.385-1.99A1.5 1.5 0 0 1 8 5z" />
                                            </svg>
                                            تحديث كلمة المرور
                                        </button>
                                    </form>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>