<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة تحكم البوت</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcode@1.4.4/build/qrcode.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</head>

<body>
    <!-- Navbar -->
    <%- include('partials/navbar') %>

        <!-- Sidebar -->
        <%- include('partials/sidebar') %>

            <div class="container-fluid main-content px-4 px-lg-5">
                <div class="glass-card p-4 p-md-5 text-center animate-fade-in">
                    <h2 class="mb-2 fw-bold">إدارة الاتصال 🔌</h2>
                    <p class="text-secondary mb-5">تحكم في حالة البوت ومسح كود QR</p>

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <div class="p-4 rounded-4" style="background: rgba(0,0,0,0.2);">
                                <h5 class="m-0 text-secondary mb-3">حالة البوت</h5>
                                <div class="d-flex flex-column align-items-center justify-content-center gap-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <span id="status-dot"
                                            class="status-dot <%= status === 'online' ? 'status-online' : (status === 'paused' ? 'bg-warning' : (status === 'paused_manual' ? 'bg-orange' : 'status-offline')) %>"
                                            style="<%= status === 'paused_manual' ? 'background-color: #fd7e14;' : '' %>"></span>
                                        <span id="status-text" class="fs-4 fw-bold">
                                            <% if (status==='online' ) { %>
                                                متصل
                                                <% } else if (status==='paused' ) { %>
                                                    متوقف مؤقتاً
                                                    <% } else if (status==='paused_manual' ) { %>
                                                        <% if (user.pause_until) { const date=new
                                                            Date(user.pause_until); if (!isNaN(date.getTime())) { const
                                                            dateStr=date.toLocaleDateString('en-GB'); const
                                                            timeStr=date.toLocaleTimeString('en-US', { hour: 'numeric' ,
                                                            minute: 'numeric' , hour12: true }); %>
                                                            تم الإيقاف مؤقتاً حتى:<br><span dir="ltr" class="fs-6">
                                                                <%= dateStr %> - <%= timeStr %>
                                                            </span>
                                                            <% } else { %>
                                                                تم الإيقاف يدوياً
                                                                <% } %>
                                                                    <% } else { %>
                                                                        تم الإيقاف يدوياً
                                                                        <% } %>
                                                                            <% } else { %>
                                                                                غير متصل
                                                                                <% } %>
                                        </span>
                                    </div>
                                    <span id="connected-phone" class="text-success fw-bold dir-ltr font-monospace"
                                        style="font-size: 1.1rem;">
                                        <%= typeof phone !=='undefined' && phone ? '📞 ' + phone : '' %>
                                    </span>
                                    <div class="mt-3 text-white-50 small">
                                        <% if (user.expiry_date) { %>
                                            ينتهي الاشتراك في: <span class="text-warning fw-bold">
                                                <%= user.expiry_date %>
                                            </span>
                                            <% } else { %>
                                                <span class="text-success fw-bold">الاشتراك مفتوح ∞</span>
                                                <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <% const today=new Date().toISOString().split('T')[0]; const isExpired=user.expiry_date &&
                                user.expiry_date < today; const isActive=user.is_active && !isExpired; %>

                                <% if (!isActive) { %>
                                    <div
                                        class="d-flex flex-column align-items-center justify-content-center h-100 text-center animate-fade-in">
                                        <div class="p-4 rounded-4 w-100"
                                            style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.3);">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48"
                                                fill="#dc3545" class="bi bi-exclamation-triangle-fill mb-3"
                                                viewBox="0 0 16 16">
                                                <path
                                                    d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                                            </svg>
                                            <h4 class="text-danger fw-bold mb-2">عذراً، انتهى اشتراكك!</h4>
                                            <p class="text-white-50 mb-0">يرجى التواصل مع الإدارة لتجديد الاشتراك
                                                واستعادة الخدمة.</p>
                                        </div>

                                        <button id="logout-btn" class="btn btn-danger btn-lg rounded-pill w-100 mt-3">
                                            <span class="d-flex align-items-center justify-content-center gap-2">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                    fill="currentColor" class="bi bi-box-arrow-right"
                                                    viewBox="0 0 16 16">
                                                    <path fill-rule="evenodd"
                                                        d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z" />
                                                    <path fill-rule="evenodd"
                                                        d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z" />
                                                </svg>
                                                تسجيل خروج
                                            </span>
                                        </button>
                                    </div>
                                    <% } else { %>
                                        <div class="d-grid gap-3 h-100 align-content-center">
                                            <button id="start-btn" class="btn btn-success btn-lg rounded-pill"
                                                <%=status==='online' ? 'disabled' : '' %>>
                                                <span class="d-flex align-items-center justify-content-center gap-2">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                        fill="currentColor" class="bi bi-play-fill" viewBox="0 0 16 16">
                                                        <path
                                                            d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z" />
                                                    </svg>
                                                    تشغيل / تحديث
                                                </span>
                                            </button>

                                            <button id="pair-btn" class="btn btn-outline-info btn-lg rounded-pill"
                                                <%=status==='online' ? 'disabled' : '' %>>
                                                <span class="d-flex align-items-center justify-content-center gap-2">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                                        fill="currentColor" class="bi bi-phone" viewBox="0 0 16 16">
                                                        <path
                                                            d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5z" />
                                                        <path d="M8 14a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" />
                                                    </svg>
                                                    ربط برقم الهاتف
                                                </span>
                                            </button>

                                            <div class="d-flex gap-2">
                                                <button id="pause-btn"
                                                    class="btn btn-warning btn-lg rounded-pill flex-grow-1"
                                                    style="color: #fff;">
                                                    <span
                                                        class="d-flex align-items-center justify-content-center gap-2">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                            fill="currentColor" class="bi bi-pause-fill"
                                                            viewBox="0 0 16 16">
                                                            <path
                                                                d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5zm5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5z" />
                                                        </svg>
                                                        إيقاف مؤقت
                                                    </span>
                                                </button>

                                                <button id="logout-btn"
                                                    class="btn btn-danger btn-lg rounded-pill flex-grow-1">
                                                    <span
                                                        class="d-flex align-items-center justify-content-center gap-2">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                            fill="currentColor" class="bi bi-box-arrow-right"
                                                            viewBox="0 0 16 16">
                                                            <path fill-rule="evenodd"
                                                                d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z" />
                                                            <path fill-rule="evenodd"
                                                                d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z" />
                                                        </svg>
                                                        تسجيل خروج
                                                    </span>
                                                </button>
                                            </div>
                                        </div>
                                        <% } %>
                        </div>
                    </div>

                    <div id="loader" class="mt-4 d-none">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-secondary">جاري إنشاء جلسة جديدة...</p>
                    </div>

                    <div id="qr-container" class="mt-4 animate-fade-in d-flex flex-column align-items-center"
                        style="display: none !important;">
                        <div class="p-3 bg-white rounded-4 d-inline-block position-relative shadow-lg">
                            <canvas id="qr-canvas"></canvas>
                        </div>

                        <div class="mt-4 w-100" style="max-width: 300px;">
                            <div class="progress"
                                style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
                                <div id="qr-progress"
                                    class="progress-bar bg-primary progress-bar-striped progress-bar-animated"
                                    role="progressbar" style="width: 100%"></div>
                            </div>
                            <div class="d-flex justify-content-between text-secondary mt-2">
                                <small class="fw-medium">سيتم تحديث الكود خلال</small>
                                <small id="timer-text" class="fw-bold text-primary">40ث</small>
                            </div>
                        </div>
                    </div>

                    <!-- Pairing Code Display -->
                    <div id="pairing-container" class="mt-4 animate-fade-in" style="display: none;">
                        <div class="p-4 rounded-4"
                            style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px);">
                            <h4 class="text-white mb-3">🔢 كود الربط الخاص بك</h4>
                            <div class="display-3 fw-bold text-warning letter-spacing-3 user-select-all"
                                id="pairing-code-display" style="letter-spacing: 5px;">
                                Loading...
                            </div>
                            <p class="text-white-50 mt-3">
                                افتتح واتساب > الأجهزة المرتبطة > ربط جهاز > "الربط برقم الهاتف بدلاً من ذلك"
                            </p>
                        </div>
                    </div>

                    <!-- Control Instructions Guide (Enhanced Design) -->
                    <div class="mt-4 rounded-4 overflow-hidden"
                        style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1);">

                        <div class="px-4 py-3 border-bottom d-flex align-items-center"
                            style="border-color: rgba(255,255,255,0.1) !important; background: rgba(0,0,0,0.1);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#10b981"
                                class="bi bi-info-circle-fill ms-2" viewBox="0 0 16 16">
                                <path
                                    d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z" />
                            </svg>
                            <h6 class="text-white mb-0 fw-bold">دليل التحكم السريع</h6>
                        </div>

                        <div class="p-4 position-relative">
                            <!-- Vertical Line -->
                            <div class="position-absolute h-100 border-end"
                                style="right: 39px; top: 0; border-color: rgba(255,255,255,0.1) !important; z-index: 0;">
                            </div>

                            <!-- Step 1 -->
                            <div class="d-flex position-relative mb-4 align-items-start gap-3">
                                <div class="flex-shrink-0" style="z-index: 1;">
                                    <div class="d-flex align-items-center justify-content-center bg-primary rounded-circle shadow fw-bold text-white"
                                        style="width: 32px; height: 32px; font-family: sans-serif;">1</div>
                                </div>
                                <div>
                                    <h6 class="text-white fw-bold mb-1">إنشاء جروب التحكم</h6>
                                    <p class="text-white-50 small mb-0 lh-base">
                                        اعمل جروب واتساب جديد وضيف البوت فيه. سمّي الجروب
                                        <span
                                            class="badge bg-dark border border-secondary text-warning fw-normal mx-1 font-monospace"
                                            dir="ltr">Lina</span>
                                        أو
                                        <span
                                            class="badge bg-dark border border-secondary text-warning fw-normal mx-1">لينا</span>
                                        علشان البوت يعرفه.
                                    </p>
                                </div>
                            </div>

                            <!-- Step 2 -->
                            <div class="d-flex position-relative mb-4 align-items-start gap-3">
                                <div class="flex-shrink-0" style="z-index: 1;">
                                    <div class="d-flex align-items-center justify-content-center bg-warning rounded-circle shadow fw-bold text-dark"
                                        style="width: 32px; height: 32px; font-family: sans-serif;">2</div>
                                </div>
                                <div class="w-100">
                                    <h6 class="text-white fw-bold mb-3">أوامر التحكم (جوة الجروب)</h6>
                                    <div class="d-flex flex-column gap-2">
                                        <!-- Stop Command -->
                                        <div
                                            class="d-flex flex-wrap flex-sm-nowrap align-items-center gap-2 bg-dark bg-opacity-25 p-2 rounded border border-secondary border-opacity-10 text-center">
                                            <div
                                                class="d-flex gap-2 align-items-center justify-content-center flex-grow-1 flex-sm-grow-0 w-100 w-sm-auto">
                                                <code
                                                    class="text-danger fw-bold bg-black bg-opacity-25 px-2 py-1 rounded border border-secondary border-opacity-25"
                                                    dir="ltr">stop</code>
                                                <span class="text-white-50 small">أو</span>
                                                <code
                                                    class="text-danger fw-bold bg-black bg-opacity-25 px-2 py-1 rounded border border-secondary border-opacity-25">ايقاف</code>
                                            </div>

                                            <div class="vr bg-secondary opacity-25 mx-2 d-none d-sm-block"></div>
                                            <div
                                                class="w-100 border-top border-secondary border-opacity-10 d-sm-none my-1">
                                            </div>

                                            <span
                                                class="text-white-50 small w-100 w-sm-auto text-center flex-grow-1">إيقاف
                                                البوت عن الرد</span>
                                        </div>

                                        <!-- Start Command -->
                                        <div
                                            class="d-flex flex-wrap flex-sm-nowrap align-items-center gap-2 bg-dark bg-opacity-25 p-2 rounded border border-secondary border-opacity-10 text-center">
                                            <div
                                                class="d-flex gap-2 align-items-center justify-content-center flex-grow-1 flex-sm-grow-0 w-100 w-sm-auto">
                                                <code
                                                    class="text-success fw-bold bg-black bg-opacity-25 px-2 py-1 rounded border border-secondary border-opacity-25"
                                                    dir="ltr">start</code>
                                                <span class="text-white-50 small">أو</span>
                                                <code
                                                    class="text-success fw-bold bg-black bg-opacity-25 px-2 py-1 rounded border border-secondary border-opacity-25">تشغيل</code>
                                            </div>

                                            <div class="vr bg-secondary opacity-25 mx-2 d-none d-sm-block"></div>
                                            <div
                                                class="w-100 border-top border-secondary border-opacity-10 d-sm-none my-1">
                                            </div>

                                            <span
                                                class="text-white-50 small w-100 w-sm-auto text-center flex-grow-1">إعادة
                                                تشغيل البوت</span>
                                        </div>

                                        <!-- Wait Command -->
                                        <div
                                            class="d-flex flex-wrap flex-sm-nowrap align-items-center gap-2 bg-dark bg-opacity-25 p-2 rounded border border-secondary border-opacity-10 text-center">
                                            <div
                                                class="d-flex gap-2 align-items-center justify-content-center flex-grow-1 flex-sm-grow-0 w-100 w-sm-auto">
                                                <code
                                                    class="text-info fw-bold bg-black bg-opacity-25 px-2 py-1 rounded border border-secondary border-opacity-25">انتظر 15 دقيقة</code>
                                            </div>

                                            <div class="vr bg-secondary opacity-25 mx-2 d-none d-sm-block"></div>
                                            <div
                                                class="w-100 border-top border-secondary border-opacity-10 d-sm-none my-1">
                                            </div>

                                            <span
                                                class="text-white-50 small w-100 w-sm-auto text-center flex-grow-1">إيقاف
                                                مؤقت لمدة
                                                محددة</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 3 -->
                            <div class="d-flex position-relative align-items-start gap-3">
                                <div class="flex-shrink-0" style="z-index: 1;">
                                    <div class="d-flex align-items-center justify-content-center bg-success rounded-circle shadow text-white"
                                        style="width: 32px; height: 32px;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                            fill="currentColor" class="bi bi-check-lg" viewBox="0 0 16 16">
                                            <path
                                                d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02-.022Z" />
                                        </svg>
                                    </div>
                                </div>
                                <div>
                                    <h6 class="text-white fw-bold mb-1">ملاحظات هامة</h6>
                                    <p class="text-white-50 small mb-0">
                                        الأوامر تعمل فقط داخل جروب التحكم المخصص لضمان الخصوصية والأمان.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Pairing Modal -->
            <div class="modal fade" id="pairModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content glass-card border-secondary">
                        <div
                            class="modal-header border-bottom border-secondary border-opacity-25 w-100 d-flex justify-content-between align-items-center">
                            <h5 class="modal-title text-white m-0">📱 الربط برقم الهاتف</h5>
                            <button type="button" class="btn-close btn-close-white m-0" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="pairForm">
                                <div class="mb-3">
                                    <label class="form-label text-white">رقم الهاتف</label>
                                    <div class="row g-2" dir="ltr">
                                        <div class="col-4">
                                            <select
                                                class="form-select form-select-lg bg-dark text-white border-secondary text-center"
                                                id="countryCode">
                                                <option value="20" selected>+20</option>
                                                <option value="966">+966</option>
                                                <option value="971">+971</option>
                                                <option value="965">+965</option>
                                                <option value="974">+974</option>
                                                <option value="968">+968</option>
                                                <option value="973">+973</option>
                                                <option value="962">+962</option>
                                                <option value="">Other</option>
                                            </select>
                                        </div>
                                        <div class="col-8">
                                            <input type="tel" id="phoneNumberInput"
                                                class="form-control form-control-lg bg-dark text-white border-secondary text-start"
                                                placeholder="10xxxxxxxx" required dir="ltr">
                                        </div>
                                    </div>
                                    <div class="form-text text-white-50 mt-2">اكتب الرقم بدون الصفر اللي في الأول
                                        (مثلاً: 10xxxx بدلاً من 010xxxx)</div>
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold">احصل على
                                        الكود</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                // --- Socket Events ---
                const socket = io();
                const userId = "<%= user.id %>";

                socket.emit('join_room', `user_${userId}`);

                const startBtn = document.getElementById('start-btn');
                const pairBtn = document.getElementById('pair-btn');
                const pauseBtn = document.getElementById('pause-btn');
                const logoutBtn = document.getElementById('logout-btn');

                const qrContainer = document.getElementById('qr-container');
                const pairingContainer = document.getElementById('pairing-container');
                const loader = document.getElementById('loader');

                const statusText = document.getElementById('status-text');
                const statusDot = document.getElementById('status-dot');
                const connectedPhone = document.getElementById('connected-phone');

                const qrCanvas = document.getElementById('qr-canvas');
                const qrProgress = document.getElementById('qr-progress');
                const timerText = document.getElementById('timer-text');
                const pairingCodeDisplay = document.getElementById('pairing-code-display');

                let timerInterval;
                let isPairingFlow = false; // Flag to suppress QR if using phone pairing

                function startQrTimer() {
                    clearInterval(timerInterval);
                    let timeLeft = 40; // Baileys QR refresh time usually
                    if (qrProgress) qrProgress.style.width = '100%';

                    timerInterval = setInterval(() => {
                        timeLeft--;
                        const percentage = (timeLeft / 40) * 100;
                        if (qrProgress) qrProgress.style.width = percentage + '%';
                        if (timerText) timerText.innerText = timeLeft + 'ث';

                        if (timeLeft <= 0) {
                            clearInterval(timerInterval);
                            if (timerText) timerText.innerText = 'جاري التحديث...';
                        }
                    }, 1000);
                }

                // --- Socket Listeners ---

                socket.on('status', (data) => {
                    console.log('Status update:', data);
                    let status = typeof data === 'string' ? data : data.status;
                    let phone = data.phone || (data.phone === undefined && typeof data !== 'string' ? '' : '');

                    // Update Phone Text if provided
                    if (data.phone) {
                        connectedPhone.innerText = `📞 ${data.phone}`;
                    }

                    if (status === 'online') {
                        statusText.innerText = 'متصل';
                        statusDot.className = 'status-dot status-online';
                        statusDot.style.backgroundColor = '#10b981'; // Green

                        // HIDE LOGIN UI
                        if (qrContainer) qrContainer.style.setProperty('display', 'none', 'important');
                        pairingContainer.style.display = 'none';
                        loader.classList.add('d-none');
                        clearInterval(timerInterval);
                        isPairingFlow = false; // Reset flow

                        // Button States
                        startBtn.disabled = true;
                        if (pairBtn) pairBtn.disabled = true;
                        pauseBtn.disabled = false;
                        logoutBtn.disabled = false;

                    } else if (status === 'paused') {
                        statusText.innerText = 'متوقف مؤقتاً';
                        statusDot.className = 'status-dot';
                        statusDot.style.backgroundColor = '#ffc107'; // Warning/Yellow

                        loader.classList.add('d-none');
                        // Allow Resume
                        startBtn.innerText = '▶ تشغيل';
                        startBtn.disabled = false;
                        if (pairBtn) pairBtn.disabled = true; // Already paired
                        pauseBtn.disabled = true;
                        logoutBtn.disabled = false;

                    } else if (status === 'paused_manual') {
                        // Manual Pause or Wait Timer
                        if (data.pause_until) {
                            const date = new Date(data.pause_until);
                            // Check if date is valid
                            if (!isNaN(date.getTime())) {
                                const dateStr = date.toLocaleDateString('en-GB');
                                const timeStr = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: 'numeric', hour12: true });
                                statusText.innerHTML = `تم الإيقاف مؤقتاً حتى:<br><span dir="ltr">${dateStr} - ${timeStr}</span>`;
                            } else {
                                statusText.innerText = 'تم الإيقاف يدوياً';
                            }
                        } else {
                            statusText.innerText = 'تم الإيقاف يدوياً';
                        }

                        statusDot.className = 'status-dot';
                        statusDot.style.backgroundColor = '#fd7e14'; // Orange

                        loader.classList.add('d-none');

                        // Allow Resume
                        startBtn.innerText = '▶ تشغيل';
                        startBtn.disabled = false;
                        if (pairBtn) pairBtn.disabled = true;
                        pauseBtn.disabled = true;
                        logoutBtn.disabled = false;

                    } else if (status === 'connecting') {
                        statusText.innerText = 'جاري الاتصال...';
                        statusDot.style.backgroundColor = '#0dcaf0'; // Info/Cyan
                        loader.classList.remove('d-none');
                        if (!isPairingFlow) qrContainer.style.display = 'none'; // Don't show QR yet if standard connecting

                    } else {
                        // offline, not_registered, timeout
                        if (status === 'not_registered') statusText.innerText = 'غير مسجل';
                        else statusText.innerText = 'غير متصل';

                        statusDot.className = 'status-dot status-offline';
                        statusDot.style.backgroundColor = '#ef4444'; // Red

                        loader.classList.add('d-none');

                        // Reset buttons
                        startBtn.innerText = '🔄 تشغيل / تحديث';
                        startBtn.disabled = false;
                        if (pairBtn) pairBtn.disabled = false;
                        pauseBtn.disabled = true;
                        logoutBtn.disabled = true; // No session to logout
                        isPairingFlow = false; // Reset flow if fully disconnected
                    }
                });

                socket.on('qr_code', (qr) => {
                    // Prevent QR if already connected
                    if (statusText.innerText === 'متصل') return;

                    // CRITICAL: Ignore QR if user is in Pairing Mode OR Pairing Code is displayed
                    if (isPairingFlow || pairingContainer.style.display === 'block') {
                        console.log('Ignoring QR code because user is in Pairing Flow');
                        return;
                    }

                    console.log('Received QR Code');
                    loader.classList.add('d-none');
                    pairingContainer.style.display = 'none'; // Hide pairing code if switching
                    qrContainer.style.setProperty('display', 'flex', 'important');

                    startQrTimer();

                    if (typeof QRCode !== 'undefined') {
                        QRCode.toCanvas(qrCanvas, qr, { width: 280, margin: 2 }, function (error) {
                            if (error) console.error(error)
                        });
                    }
                });

                // Helper to copy code
                window.copyPairingCode = function (code) {
                    if (navigator && navigator.clipboard) {
                        navigator.clipboard.writeText(code).then(() => {
                            // Valid feedback (could be toast, but alert is reliable)
                            const btn = document.querySelector('.btn-copy-code');
                            if (btn) {
                                const originalText = btn.innerHTML;
                                btn.innerHTML = '<i class="fas fa-check me-2"></i> تم النسخ';
                                btn.classList.remove('btn-outline-warning');
                                btn.classList.add('btn-success');
                                setTimeout(() => {
                                    btn.innerHTML = originalText;
                                    btn.classList.add('btn-outline-warning');
                                    btn.classList.remove('btn-success');
                                }, 2000);
                            }
                        });
                    } else {
                        // Fallback
                        const input = document.createElement('input');
                        input.value = code;
                        document.body.appendChild(input);
                        input.select();
                        document.execCommand('copy');
                        document.body.removeChild(input);
                        alert('تم نسخ الكود');
                    }
                };

                socket.on('pairing_code', (code) => {
                    if (statusText.innerText === 'متصل') return;

                    loader.classList.add('d-none');
                    // FORCE HIDE QR
                    qrContainer.style.setProperty('display', 'none', 'important');
                    pairingContainer.style.display = 'block';

                    // FORMAT: Vertical Layout with Copy Button
                    if (code && code.length >= 8) {
                        const p1 = code.slice(0, 4);
                        const p2 = code.slice(4);
                        pairingCodeDisplay.innerHTML = `
                            <div class="d-flex flex-column align-items-center justify-content-center" dir="ltr">
                                <div class="display-3 fw-bold text-warning" style="letter-spacing: 2px;">${p1}</div>
                                <div class="h2 text-white-50 my-2">-</div>
                                <div class="display-3 fw-bold text-warning" style="letter-spacing: 2px;">${p2}</div>
                                <div class="mt-4">
                                    <button onclick="copyPairingCode('${code}')" class="btn btn-outline-warning btn-lg rounded-pill px-5 py-2 btn-copy-code">
                                        <i class="fas fa-copy me-2"></i> نسخ
                                    </button>
                                </div>
                            </div>
                        `;
                    } else {
                        pairingCodeDisplay.innerText = code.split('').join(' ');
                    }
                });

                socket.on('pairing_error', (err) => {
                    loader.classList.add('d-none');
                    statusText.innerText = 'خطأ';
                    alert('خطأ في الربط: ' + err);
                    isPairingFlow = false; // Reset on error so they can try again or use QR
                });

                // --- Event Listeners ---

                // 1. Pairing Modal & Form
                const pairModalElement = document.getElementById('pairModal');
                const pairModal = pairModalElement ? new bootstrap.Modal(pairModalElement) : null;
                const pairForm = document.getElementById('pairForm');

                if (pairBtn) {
                    pairBtn.addEventListener('click', () => {
                        if (pairModal) pairModal.show();
                    });
                }

                if (pairForm) {
                    pairForm.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        const code = document.getElementById('countryCode').value;
                        let number = document.getElementById('phoneNumberInput').value;
                        if (code && number.startsWith('0')) number = number.substring(1); // Remove leading zero

                        const phoneNumber = code + number;

                        if (pairModal) pairModal.hide();

                        // UI Setup for Pairing
                        isPairingFlow = true; // SET FLAG
                        loader.classList.remove('d-none');
                        qrContainer.style.setProperty('display', 'none', 'important');
                        pairingContainer.style.display = 'none';
                        statusText.innerText = 'جاري طلب الكود...';

                        try {
                            const response = await fetch('/dashboard/pair-bot', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ phoneNumber })
                            });
                            // Result handled by socket 'pairing_code' or 'pairing_error'
                        } catch (err) {
                            console.error(err);
                            alert("Error requesting code");
                            loader.classList.add('d-none');
                            isPairingFlow = false; // Reset on error
                        }
                    });
                }

                // 2. Start / Restart
                if (startBtn) {
                    startBtn.addEventListener('click', async () => {
                        isPairingFlow = false; // Reset flag so QR can show
                        loader.classList.remove('d-none');
                        startBtn.disabled = true;

                        // Clear old QR
                        qrContainer.style.setProperty('display', 'none', 'important');
                        pairingContainer.style.display = 'none';

                        try {
                            const response = await fetch('/dashboard/start-bot', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            if (!response.ok) throw new Error('Failed to start');
                        } catch (err) {
                            console.error(err);
                            // alert('Error starting bot');
                            loader.classList.add('d-none');
                            startBtn.disabled = false;
                        }
                    });
                }

                // 3. Pause
                if (pauseBtn) {
                    pauseBtn.addEventListener('click', async () => {
                        if (confirm('هل أنت متأكد من إيقاف البوت مؤقتاً؟\n(لن يتم الرد على الرسائل، لكن الجلسة ستظل نشطة)')) {
                            try {
                                const response = await fetch('/dashboard/stop-bot', { method: 'POST' });
                                if (!response.ok) throw new Error('Failed to pause');
                            } catch (err) { alert(err.message); }
                        }
                    });
                }

                // 4. Logout
                if (logoutBtn) {
                    logoutBtn.addEventListener('click', async () => {
                        if (confirm('هل أنت متأكد من تسجيل الخروج وحذف الجلسة نهائياً؟\n(ستحتاج لمسح الكود مرة أخرى)')) {
                            try {
                                loader.classList.remove('d-none');
                                const response = await fetch('/dashboard/logout-bot', { method: 'POST' });
                                if (!response.ok) throw new Error('Logout failed');

                                // Reset UI immediately
                                statusText.innerText = 'غير مسجل';
                                connectedPhone.innerText = '';
                                qrContainer.style.setProperty('display', 'none', 'important');
                                pairingContainer.style.display = 'none';
                                loader.classList.add('d-none');
                                isPairingFlow = false; // Reset flow

                                location.reload();
                            } catch (err) { alert(err.message); }
                        }
                    });
                }
            </script>
</body>

</html>