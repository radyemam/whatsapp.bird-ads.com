<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم - سوبر أدمن</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
</head>

<body>
    <%- include('partials/navbar') %>

        <div class="container-fluid px-4 px-lg-5" style="margin-top: 100px;">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="glass-card p-4 animate-fade-in">
                        <h5 class="mb-4 d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="var(--primary-color)"
                                class="bi bi-person-plus-fill" viewBox="0 0 16 16">
                                <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                                <path fill-rule="evenodd"
                                    d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z" />
                            </svg>
                            إضافة مستخدم جديد
                        </h5>
                        <form action="/admin/create-user" method="POST">
                            <div class="mb-3">
                                <input type="text" name="username" class="form-control" placeholder="اسم المستخدم"
                                    required>
                            </div>
                            <div class="mb-3">
                                <input type="password" name="password" class="form-control" placeholder="كلمة المرور"
                                    required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white small">تاريخ انتهاء الاشتراك (اختياري)</label>
                                <input type="date" name="expiry_date" class="form-control" style="color-scheme: dark;">
                            </div>
                            <button type="submit" class="btn btn-success w-100 py-2">إضافة مستخدم</button>
                        </form>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="glass-card p-4 animate-fade-in" style="animation-delay: 0.1s;">
                        <h5 class="mb-4">قائمة المستخدمين المسجلين</h5>
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>اسم المستخدم</th>
                                        <th>حالة الحساب</th>
                                        <th>حالة البوت</th>
                                        <th>استهلاك التوكن</th>
                                        <th>التكلفة (تقريبي)</th>
                                        <th>تاريخ الانتهاء</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% users.forEach(user=> { %>
                                        <tr>
                                            <td>
                                                <%= user.id %>
                                            </td>
                                            <td class="fw-bold">
                                                <%= user.username %>
                                            </td>
                                            <td>
                                                <% const today=new Date().toISOString().split('T')[0]; const
                                                    userExpiry=user.expiry_date ? String(user.expiry_date) : null; const
                                                    isExpired=userExpiry && userExpiry < today; %>
                                                    <% if (isExpired) { %>
                                                        <span class="badge rounded-pill bg-danger">منتهي</span>
                                                        <% } else { %>
                                                            <span
                                                                class="badge rounded-pill <%= user.is_active ? 'bg-success' : 'bg-secondary' %>">
                                                                <%= user.is_active ? 'مفعل' : 'موقوف' %>
                                                            </span>
                                                            <% } %>
                                            </td>
                                            <td>
                                                <% let statusColor='bg-secondary' ; let statusText='غير معروف' ; const
                                                    s=user.connection_status || 'offline' ; if (s==='online' ) {
                                                    statusColor='bg-success' ; statusText='متصل' ; } else if
                                                    (s==='offline' ) { statusColor='bg-dark' ; statusText='غير متصل' ; }
                                                    else if (s==='paused' ) { statusColor='bg-warning text-dark' ;
                                                    statusText='موقوف مؤقتاً' ; } else if (s==='not_registered' ) {
                                                    statusColor='bg-danger' ; statusText='غير مسجل' ; } else if
                                                    (s==='connecting' ) { statusColor='bg-info text-dark' ;
                                                    statusText='جاري الاتصال' ; } %>
                                                    <span class="badge rounded-pill <%= statusColor %> border">
                                                        <%= statusText %>
                                                    </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    <%= user.total_tokens || 0 %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    <%= ((user.total_tokens || 0) * 0.0005).toFixed(2) %> EGP
                                                </span>
                                            </td>
                                            <td>
                                                <% if (user.expiry_date) { %>
                                                    <span class="badge bg-light text-dark border">
                                                        <%= user.expiry_date %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge bg-success text-white border">مفتوح ∞</span>
                                                        <% } %>
                                            </td>
                                            <td>
                                                <% if(user.role !=='super_admin' ) { %>
                                                    <div class="d-flex gap-2">
                                                        <form action="/admin/toggle-status/<%= user.id %>"
                                                            method="POST">
                                                            <button
                                                                class="btn btn-sm <%= user.is_active ? 'btn-outline-warning' : 'btn-outline-secondary' %>"
                                                                title="<%= user.is_active ? 'تعطيل الحساب' : 'تفعيل الحساب' %>">
                                                                <% if (user.is_active) { %>
                                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16"
                                                                        height="16" fill="currentColor"
                                                                        class="bi bi-toggle-on" viewBox="0 0 16 16">
                                                                        <path
                                                                            d="M5 3a5 5 0 0 0 0 10h6a5 5 0 0 0 0-10H5zm6 9a4 4 0 1 1 0-8 4 4 0 0 1 0 8z" />
                                                                    </svg>
                                                                    <% } else { %>
                                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                                            width="16" height="16" fill="currentColor"
                                                                            class="bi bi-toggle-off"
                                                                            viewBox="0 0 16 16">
                                                                            <path
                                                                                d="M11 4a4 4 0 0 1 0 8H8a4.992 4.992 0 0 0 2-4 4.992 4.992 0 0 0-2-4h3zm-6 8a4 4 0 1 1 0-8 4 4 0 0 1 0 8zM0 8a5 5 0 0 0 5 5h6a5 5 0 0 0 0-10H5a5 5 0 0 0-5 5z" />
                                                                        </svg>
                                                                        <% } %>
                                                            </button>
                                                        </form>

                                                        <button class="btn btn-sm btn-outline-secondary"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#settingsModal<%= user.id %>"
                                                            title="إعدادات">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="16"
                                                                height="16" fill="currentColor" class="bi bi-gear-fill"
                                                                viewBox="0 0 16 16">
                                                                <path
                                                                    d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z" />
                                                            </svg>
                                                        </button>

                                                        <!-- Settings Modal Removed from here -->

                                                        <form action="/admin/delete-user/<%= user.id %>" method="POST">
                                                            <button class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('حذف نهائي؟')" title="حذف">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="16"
                                                                    height="16" fill="currentColor"
                                                                    class="bi bi-trash-fill" viewBox="0 0 16 16">
                                                                    <path
                                                                        d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1H2.5zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5zM8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5zm3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0z" />
                                                                </svg>
                                                            </button>
                                                        </form>
                                                    </div>
                                                    <% } %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modals Container -->
        <% users.forEach(user=> { %>
            <div class="modal fade" id="settingsModal<%= user.id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content text-white"
                        style="background-color: #161b22; border: 1px solid rgba(255,255,255,0.1);">
                        <div class="modal-header border-bottom border-secondary border-opacity-25">
                            <h5 class="modal-title">إعدادات المستخدم: <%= user.username %>
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form action="/admin/update-expiry/<%= user.id %>" method="POST">
                                <div class="mb-3">
                                    <label class="form-label text-white">تاريخ انتهاء الاشتراك</label>
                                    <input type="date" name="expiry_date" class="form-control"
                                        style="color-scheme: dark;"
                                        value="<%= user.expiry_date ? user.expiry_date : '' %>">
                                    <div class="form-text text-white-50">اتركه فارغاً للاشتراك المفتوح.</div>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">حفظ التغييرات</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>