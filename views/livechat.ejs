<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Chat — لينا بوت</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
    <style>
        .livechat-card {
            height: calc(100vh - 150px);
            min-height: 500px;
            display: flex;
            overflow: hidden;
            border-radius: 16px;
        }

        /* --- Contacts Panel --- */
        .lc-contacts {
            width: 300px;
            min-width: 260px;
            flex-shrink: 0;
            background: rgba(15, 23, 42, 0.6);
            border-left: 1px solid rgba(255,255,255,0.07);
            display: flex;
            flex-direction: column;
        }
        .lc-contacts-header {
            padding: 16px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .lc-search {
            padding: 10px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .lc-search input {
            width: 100%;
            background: rgba(30,41,59,0.8);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 10px;
            padding: 8px 12px;
            font-size: 13px;
        }
        .lc-search input:focus { outline: none; border-color: #6366f1; }
        .lc-contacts-list { flex: 1; overflow-y: auto; }
        .lc-contact {
            padding: 12px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .lc-contact:hover { background: rgba(99,102,241,0.08); }
        .lc-contact.active { background: rgba(99,102,241,0.18); border-right: 3px solid #6366f1; }

        .lc-avatar {
            width: 42px; height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 16px; color: white;
            flex-shrink: 0; position: relative;
        }
        .handoff-dot {
            position: absolute; top: 0; right: 0;
            width: 12px; height: 12px;
            border-radius: 50%; background: #f59e0b;
            border: 2px solid #0f172a;
        }
        .lc-contact-info { flex: 1; overflow: hidden; }
        .lc-contact-name { font-size: 13px; font-weight: 600; color: #f1f5f9; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .lc-contact-preview { font-size: 12px; color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
        .lc-contact-meta { flex-shrink: 0; text-align: left; }
        .lc-time { font-size: 10px; color: #475569; }
        .unread-pill {
            background: #6366f1; color: white;
            border-radius: 10px; padding: 1px 6px;
            font-size: 11px; font-weight: 700;
            margin-top: 3px; display: inline-block;
        }

        /* --- Chat Panel --- */
        .lc-chat {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #0b1120;
            min-width: 0;
        }
        .lc-chat-header {
            padding: 12px 18px;
            background: rgba(15,23,42,0.8);
            border-bottom: 1px solid rgba(255,255,255,0.07);
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        .lc-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .lc-bubble {
            max-width: 70%;
            padding: 10px 14px;
            border-radius: 16px;
            font-size: 13px;
            line-height: 1.6;
            word-break: break-word;
        }
        .lc-bubble-in { background: #1e293b; color: #cbd5e1; align-self: flex-end; border-bottom-right-radius: 4px; }
        .lc-bubble-out { background: linear-gradient(135deg, #4f46e5, #6366f1); color: white; align-self: flex-start; border-bottom-left-radius: 4px; }
        .lc-bubble-time { font-size: 10px; opacity: 0.55; margin-top: 4px; }
        .lc-input-area {
            padding: 12px 16px;
            background: rgba(15,23,42,0.8);
            border-top: 1px solid rgba(255,255,255,0.07);
            display: flex; gap: 10px; align-items: flex-end;
            flex-shrink: 0;
        }
        .lc-input-area textarea {
            flex: 1;
            background: #1e293b;
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 12px;
            padding: 10px 14px;
            resize: none;
            font-size: 13px;
            min-height: 42px;
            max-height: 120px;
        }
        .lc-input-area textarea:focus { outline: none; border-color: #6366f1; }
        .btn-lc-send {
            background: linear-gradient(135deg, #4f46e5, #6366f1);
            color: white; border: none; border-radius: 12px;
            padding: 10px 18px; cursor: pointer;
            font-weight: 600; font-size: 13px;
            transition: opacity 0.2s;
        }
        .btn-lc-send:hover { opacity: 0.9; }
        .lc-empty {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center; gap: 12px;
            color: #334155;
        }

        .badge-handoff { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); border-radius: 8px; padding: 3px 10px; font-size: 12px; font-weight: 600; }
        .badge-bot { background: rgba(99,102,241,0.15); color: #818cf8; border: 1px solid rgba(99,102,241,0.3); border-radius: 8px; padding: 3px 10px; font-size: 12px; font-weight: 600; }

        /* Mobile */
        @media (max-width: 768px) {
            .lc-contacts { width: 100%; min-width: unset; border-left: none; border-bottom: 1px solid rgba(255,255,255,0.07); max-height: 220px; }
            .livechat-card { flex-direction: column; height: auto; min-height: calc(100vh - 130px); }
        }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/sidebar', { handoffCount: conversations.filter(c=>c.is_handoff).length }) %>

    <div class="container-fluid main-content px-4 px-lg-5">
        <!-- Page Title -->
        <div class="d-flex align-items-center justify-content-between mb-3 animate-fade-in">
            <div>
                <h4 class="fw-bold text-white m-0"><i class="bi bi-chat-dots-fill me-2" style="color:#6366f1;"></i>Live Chat</h4>
                <p class="text-white-50 small m-0">ردّ مباشرة على عملائك وتحكّم في البوت</p>
            </div>
            <div class="d-flex gap-2">
                <span class="badge rounded-pill" style="background:rgba(245,158,11,0.15);color:#f59e0b;border:1px solid rgba(245,158,11,0.3);font-size:12px;">
                    <i class="bi bi-person-fill me-1"></i><%= conversations.filter(c=>c.is_handoff).length %> تحويل نشط
                </span>
                <span class="badge rounded-pill" style="background:rgba(99,102,241,0.15);color:#818cf8;border:1px solid rgba(99,102,241,0.3);font-size:12px;">
                    <i class="bi bi-chat-fill me-1"></i><%= conversations.length %> محادثة
                </span>
            </div>
        </div>

        <!-- Main Chat Card -->
        <div class="glass-card p-0 animate-fade-in livechat-card">

            <!-- Contacts Panel -->
            <div class="lc-contacts">
                <div class="lc-contacts-header">
                    <span class="fw-bold text-white" style="font-size:14px;">المحادثات</span>
                </div>
                <div class="lc-search">
                    <input type="text" id="lcSearch" placeholder="🔍 ابحث...">
                </div>
                <div class="lc-contacts-list" id="lcContactsList">
                    <% if (conversations.length === 0) { %>
                    <div class="text-center p-4" style="color:#475569; font-size:13px;">
                        <i class="bi bi-chat-square-dots" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.4;"></i>
                        لا توجد محادثات بعد.<br>ستظهر هنا فور وصول أول رسالة.
                    </div>
                    <% } %>
                    <% conversations.forEach(conv => {
                        const displayName = conv.customerName || conv.remoteJid.split('@')[0];
                        const timeStr = new Date(conv.lastMessageAt).toLocaleTimeString('ar-EG', {hour:'2-digit', minute:'2-digit'});
                    %>
                    <div class="lc-contact"
                         data-jid="<%= conv.remoteJid %>"
                         data-handoff="<%= conv.is_handoff %>"
                         data-name="<%= displayName.replace(/"/g, '') %>"
                         onclick="loadChat('<%= conv.remoteJid %>', '<%= displayName.replace(/'/g,'') %>', <%= conv.is_handoff %>)">
                        <div class="lc-avatar">
                            <%= displayName[0].toUpperCase() %>
                            <% if (conv.is_handoff) { %><div class="handoff-dot"></div><% } %>
                        </div>
                        <div class="lc-contact-info">
                            <div class="lc-contact-name"><%= displayName %></div>
                            <div class="lc-contact-preview"><%= conv.lastMessageText || '...' %></div>
                        </div>
                        <div class="lc-contact-meta">
                            <div class="lc-time"><%= timeStr %></div>
                            <% if (conv.unreadCount > 0) { %>
                            <span class="unread-pill"><%= conv.unreadCount %></span>
                            <% } %>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- Chat Panel -->
            <div class="lc-chat">
                <!-- Empty State -->
                <div class="lc-empty" id="lcEmpty">
                    <i class="bi bi-chat-left-dots" style="font-size:3.5rem;opacity:0.2;"></i>
                    <p style="font-size:14px;">اختر محادثة من القائمة للبدء</p>
                </div>

                <!-- Active Chat -->
                <div id="lcActiveChat" style="display:none; flex-direction:column; height:100%;">
                    <div class="lc-chat-header">
                        <div class="d-flex align-items-center gap-3">
                            <div class="lc-avatar" id="lcHeaderAvatar" style="width:38px;height:38px;font-size:15px;">?</div>
                            <div>
                                <div class="fw-bold text-white" style="font-size:14px;" id="lcHeaderName">-</div>
                                <div style="font-size:11px;color:#64748b;" id="lcHeaderJid">-</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span id="lcStatusBadge" class="badge-bot">🤖 البوت يرد</span>
                            <button class="btn btn-sm btn-warning fw-semibold" id="lcToggleBtn" onclick="toggleHandoff()" style="font-size:12px;">
                                <i class="bi bi-person-fill-gear me-1"></i>خذ التحكم
                            </button>
                        </div>
                    </div>

                    <div class="lc-messages" id="lcMessages"></div>

                    <div class="lc-input-area">
                        <textarea id="lcInput" placeholder="اكتب ردك هنا... (Enter للإرسال، Shift+Enter لسطر جديد)" rows="1"></textarea>
                        <button class="btn-lc-send" onclick="sendLcMsg()"><i class="bi bi-send-fill"></i></button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
    let currentJid = null;
    let currentHandoff = false;
    const socket = io();

    socket.on('connect', () => socket.emit('join_room', 'user_<%= user.id %>'));
    socket.on('new_message', (msg) => {
        // Update contact preview
        const item = document.querySelector(`.lc-contact[data-jid="${msg.remoteJid}"]`);
        if (item) item.querySelector('.lc-contact-preview').textContent = msg.content;
        // Append to chat if open
        if (msg.remoteJid === currentJid && msg.role === 'user') {
            appendBubble(msg.content, true, new Date(msg.createdAt));
        }
    });

    // Search
    document.getElementById('lcSearch').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.lc-contact').forEach(el => {
            const n = el.dataset.name.toLowerCase();
            el.style.display = n.includes(q) ? '' : 'none';
        });
    });

    async function loadChat(jid, name, isHandoff) {
        currentJid = jid;
        currentHandoff = isHandoff;

        document.querySelectorAll('.lc-contact').forEach(el => el.classList.toggle('active', el.dataset.jid === jid));
        document.getElementById('lcEmpty').style.display = 'none';
        const view = document.getElementById('lcActiveChat');
        view.style.display = 'flex';
        document.getElementById('lcHeaderAvatar').textContent = name[0]?.toUpperCase() || '?';
        document.getElementById('lcHeaderName').textContent = name;
        document.getElementById('lcHeaderJid').textContent = jid;
        updateHandoffUI(isHandoff);

        // Load messages
        const res = await fetch(`/dashboard/livechat/${encodeURIComponent(jid)}/messages`);
        const data = await res.json();
        const box = document.getElementById('lcMessages');
        box.innerHTML = '';
        if (data.messages) data.messages.forEach(m => appendBubble(m.content, m.role === 'user', new Date(m.createdAt)));
        box.scrollTop = box.scrollHeight;

        // Clear unread
        const item = document.querySelector(`.lc-contact[data-jid="${jid}"]`);
        if (item) { const u = item.querySelector('.unread-pill'); if(u) u.remove(); }
    }

    function appendBubble(text, isIncoming, date) {
        const box = document.getElementById('lcMessages');
        const div = document.createElement('div');
        div.className = `lc-bubble ${isIncoming ? 'lc-bubble-in' : 'lc-bubble-out'}`;
        const t = date ? date.toLocaleTimeString('ar-EG', {hour:'2-digit', minute:'2-digit'}) : '';
        div.innerHTML = `${text.replace(/\n/g,'<br>')}<div class="lc-bubble-time">${t}</div>`;
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
    }

    async function sendLcMsg() {
        const input = document.getElementById('lcInput');
        const text = input.value.trim();
        if (!text || !currentJid) return;
        input.value = '';
        input.style.height = 'auto';
        appendBubble(text, false, new Date());

        const res = await fetch('/dashboard/livechat/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ remoteJid: currentJid, text })
        });
        const data = await res.json();
        if (!data.success) alert('فشل إرسال الرسالة: ' + (data.error || 'خطأ'));
    }

    async function toggleHandoff() {
        if (!currentJid) return;
        const newVal = !currentHandoff;
        const res = await fetch('/dashboard/livechat/handoff', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ remoteJid: currentJid, enable: newVal })
        });
        const data = await res.json();
        if (data.success) {
            currentHandoff = newVal;
            updateHandoffUI(newVal);
            const item = document.querySelector(`.lc-contact[data-jid="${currentJid}"]`);
            if (item) {
                item.dataset.handoff = newVal;
                let dot = item.querySelector('.handoff-dot');
                if (newVal && !dot) { dot = document.createElement('div'); dot.className = 'handoff-dot'; item.querySelector('.lc-avatar').appendChild(dot); }
                else if (!newVal && dot) dot.remove();
            }
        }
    }

    function updateHandoffUI(isHandoff) {
        const badge = document.getElementById('lcStatusBadge');
        const btn   = document.getElementById('lcToggleBtn');
        if (isHandoff) {
            badge.className = 'badge-handoff'; badge.textContent = '👤 أنت تتحكم';
            btn.className   = 'btn btn-sm btn-success fw-semibold'; btn.style.fontSize = '12px';
            btn.innerHTML   = '<i class="bi bi-robot me-1"></i>إرجاع للبوت';
        } else {
            badge.className = 'badge-bot'; badge.textContent = '🤖 البوت يرد';
            btn.className   = 'btn btn-sm btn-warning fw-semibold'; btn.style.fontSize = '12px';
            btn.innerHTML   = '<i class="bi bi-person-fill-gear me-1"></i>خذ التحكم';
        }
    }

    // Auto resize textarea
    const lcInput = document.getElementById('lcInput');
    lcInput.addEventListener('input', function() { this.style.height = 'auto'; this.style.height = Math.min(this.scrollHeight, 120) + 'px'; });
    lcInput.addEventListener('keydown', function(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendLcMsg(); } });
    </script>
</body>
</html>
