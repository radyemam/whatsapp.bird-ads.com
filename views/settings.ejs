<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إعدادات البوت</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/style.css" rel="stylesheet">
    <style>
        .main-content {
            margin-right: 320px;
            padding-top: 100px;
            transition: all 0.3s;
        }

        @media (max-width: 992px) {
            .main-content {
                margin-right: 0;
                margin-top: 30px;
                padding-top: 20px;
            }
        }

        textarea.form-control {
            background-color: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e2e8f0;
            resize: none;
        }

        textarea.form-control:focus {
            background-color: rgba(15, 23, 42, 0.8);
            border-color: var(--primary-color);
            color: white;
            box-shadow: none;
        }
    </style>
</head>

<body>
    <%- include('partials/navbar') %>
        <%- include('partials/sidebar') %>

            <div class="container-fluid main-content px-4 px-lg-5">
                <div class="glass-card p-4 p-md-5 animate-fade-in">
                    <h2 class="mb-4 fw-bold d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="var(--primary-color)"
                            class="bi bi-sliders" viewBox="0 0 16 16">
                            <path fill-rule="evenodd"
                                d="M11.5 2a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM9.05 3a2.5 2.5 0 0 1 4.9 0H16v1h-2.05a2.5 2.5 0 0 1-4.9 0H0V3h9.05zM4.5 7a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM2.05 8a2.5 2.5 0 0 1 4.9 0H16v1H6.95a2.5 2.5 0 0 1-4.9 0H0V8h2.05zm9.45 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm-2.45 1a2.5 2.5 0 0 1 4.9 0H16v1h-2.05a2.5 2.5 0 0 1-4.9 0H0v-1h9.05z" />
                        </svg>
                        إعدادات البوت
                    </h2>

                    <form action="/dashboard/settings" method="POST">
                        <div class="mb-4">
                            <label class="form-label text-white fw-bold mb-2">تعليمات النظام (System Prompt)</label>
                            <p class="text-secondary small mb-2">هنا يمكنك تحديد شخصية البوت، طريقة رده، وما يجب أن
                                يفعله.</p>
                            <textarea name="system_instruction" class="form-control" rows="12"
                                placeholder="أنت مساعد ذكي لخدمة العملاء..."><%= user.system_instruction || '' %></textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                    class="bi bi-save2 me-2" viewBox="0 0 16 16">
                                    <path
                                        d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z" />
                                </svg>
                                حفظ التغييرات
                            </button>
                        </div>
                    </form>
                </div>
            </div>
</body>

</html>